# AEC Demo Portable — DGX Spark runtime configuration
# Copy to config/runtime.env and edit locally. This file contains no secrets.

# The controller exports AEC_PORTABLE_ROOT as this repository's absolute path.
AEC_PORTABLE_SHARED_ROOT=$AEC_PORTABLE_ROOT
# Isolated Rhino 3DM reader used by the checked FreeCAD site adapter.
AEC_PORTABLE_CAD_PYTHON=$AEC_PORTABLE_ROOT/runtime/cad-tools/bin/python
# Local Hermes agent and Ollama model used by the human-gated demo.
AEC_PORTABLE_HERMES_BIN=$HOME/.local/bin/hermes
AEC_HERMES_MODEL=ollama/qwen3.6:latest
AEC_PORTABLE_OLLAMA_MODEL=qwen3.6:latest
AEC_PORTABLE_REQUIRE_HERMES=1

# FreeCAD is the Spark replacement track for Rhino. The portable launcher
# repairs its MCP links and exposes XML-RPC on localhost:9875.
AEC_PORTABLE_FREECAD_ENABLED=1
AEC_PORTABLE_FREECAD_START=$AEC_PORTABLE_ROOT/scripts/start-freecad.sh
AEC_PORTABLE_FREECAD_EXE=$AEC_PORTABLE_ROOT/runtime/freecad/FreeCAD_1.1.1-Linux-aarch64-py311.AppImage

# The delivered scenes require Blender 5.1. The Spark ARM64 runtime is isolated
# under runtime/blender and carries its own private shared libraries.
AEC_PORTABLE_BLENDER_EXE=$AEC_PORTABLE_ROOT/scripts/blender-portable.sh
AEC_PORTABLE_BLENDER_MIN_VERSION=5.1
AEC_PORTABLE_BLENDER_SCENE=$AEC_PORTABLE_ROOT/sample_project/blender_assets/cliff_house_act2_textured_v3.blend
AEC_PORTABLE_BLENDER_PORT=9876
AEC_PORTABLE_BLENDER_MCP_BOOTSTRAP=$AEC_PORTABLE_ROOT/scripts/start_blender_mcp.py
AEC_PORTABLE_BLENDER_MCP_ADDON=$AEC_PORTABLE_ROOT/setup/blender_addons/BlenderMCP_addon.py
AEC_PORTABLE_DISPLAY=:1
AEC_PORTABLE_XAUTHORITY=/run/user/1000/gdm/Xauthority

# Isolated CUDA 13 ComfyUI runtime for the delivered Flux.2 Klein graph.
AEC_PORTABLE_COMFY_ROOT=$AEC_PORTABLE_ROOT/runtime/comfyui
AEC_PORTABLE_COMFY_PYTHON=$AEC_PORTABLE_ROOT/runtime/comfyui/.venv/bin/python
AEC_PORTABLE_COMFY_PORT=8188
AEC_PORTABLE_COMFY_URL=http://127.0.0.1:8188
AEC_PORTABLE_REQUIRE_MODELS=1

# Local service endpoints only.
AEC_PORTABLE_FREECAD_PORT=9875
AEC_PORTABLE_HOST=127.0.0.1
