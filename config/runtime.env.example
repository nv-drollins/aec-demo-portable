# AEC Demo Portable — DGX Spark runtime configuration
# Copy to config/runtime.env and edit locally. This file contains no secrets.

# Reuse the previously validated local runtime while this bundle is ported.
AEC_PORTABLE_SHARED_ROOT=/home/nvidia/aec-demo

# FreeCAD is the Spark replacement track for Rhino. The shared launcher repairs
# its MCP links and exposes XML-RPC on localhost:9875.
AEC_PORTABLE_FREECAD_ENABLED=1
AEC_PORTABLE_FREECAD_START=/home/nvidia/aec-demo/scripts/start-freecad.sh

# The delivered sample scenes require Blender 5.1. `blender` currently resolves
# to Ubuntu Blender 4.0 on this Spark, so strict preflight will block until a
# compatible Blender executable is configured here.
AEC_PORTABLE_BLENDER_EXE=blender
AEC_PORTABLE_BLENDER_MIN_VERSION=5.1
AEC_PORTABLE_BLENDER_SCENE=/home/nvidia/AEC_Demo_Portable/sample_project/blender_assets/cliff_house_act2_textured_v3.blend
AEC_PORTABLE_BLENDER_PORT=9876

# Existing local ComfyUI runtime. The portable graph requires the Flux.2 Klein
# models listed in comfyui/models/MODEL_MANIFEST.md.
AEC_PORTABLE_COMFY_ROOT=/home/nvidia/aec-demo/comfyui
AEC_PORTABLE_COMFY_PYTHON=/home/nvidia/aec-demo/comfyui/.venv/bin/python
AEC_PORTABLE_COMFY_PORT=8188
AEC_PORTABLE_REQUIRE_MODELS=1

# Local service endpoints only.
AEC_PORTABLE_FREECAD_PORT=9875
AEC_PORTABLE_HOST=127.0.0.1
